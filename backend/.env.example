# Base de datos
LAB_DATABASE_URL=postgresql+psycopg2://luca@localhost:5432/laboratorio_contenido
LAB_DATABASE_URL_TEST=postgresql+psycopg2://luca@localhost:5432/laboratorio_contenido_test

# Token máquina-a-máquina para la ingesta (n8n lo manda en el header X-Ingest-Token)
LAB_INGEST_TOKEN=dev-ingest-token-change-me

# Webhooks de n8n (dejar vacío hasta tener n8n corriendo con los workflows importados)
LAB_N8N_PING_WEBHOOK_URL=
LAB_N8N_INGEST_WEBHOOK_URL=

# Guardas del sync on-demand
LAB_SYNC_STALE_MINUTES=5
LAB_SYNC_STUCK_MINUTES=10
LAB_N8N_PING_TIMEOUT_SECONDS=2.0
